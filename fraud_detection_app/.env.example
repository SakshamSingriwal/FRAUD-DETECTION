# ── Sentinel environment variables (copy to .env; all optional) ──────────────

# Default AutoML time budget in seconds (UI can still override).
AUTOML_TIME_LIMIT=90

# Default expected anomaly rate for unsupervised detectors.
ANOMALY_CONTAMINATION=0.05

# ── Optional alerting (not wired by default; placeholders for deployment) ────
# Slack / Discord incoming webhook to notify on high-risk batches.
ALERT_WEBHOOK_URL=
# SMTP for emailed reports.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=
